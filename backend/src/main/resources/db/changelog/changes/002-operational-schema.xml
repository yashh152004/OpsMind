<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.3.xsd">

    <changeSet id="2" author="opsmind">
        <createTable tableName="incidents">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="organization_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="title" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="TEXT"/>
            <column name="status" type="VARCHAR(50)" defaultValue="OPEN">
                <constraints nullable="false"/>
            </column>
            <column name="priority" type="VARCHAR(50)" defaultValue="P3">
                <constraints nullable="false"/>
            </column>
            <column name="service_name" type="VARCHAR(100)"/>
            <column name="assigned_to" type="UUID"/>
            <column name="resolved_at" type="TIMESTAMP WITH TIME ZONE"/>
            <column name="root_cause" type="TEXT"/>
            <column name="ai_summary" type="TEXT"/>
            <column name="metadata" type="JSONB" defaultValue="{}"/>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createTable tableName="alerts">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="organization_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="incident_id" type="UUID"/>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="message" type="TEXT"/>
            <column name="severity" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(50)" defaultValue="TRIGGERED">
                <constraints nullable="false"/>
            </column>
            <column name="source" type="VARCHAR(100)"/>
            <column name="external_id" type="VARCHAR(255)"/>
            <column name="labels" type="JSONB" defaultValue="{}"/>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="resolved_at" type="TIMESTAMP WITH TIME ZONE"/>
        </createTable>

        <createIndex indexName="idx_incidents_org" tableName="incidents">
            <column name="organization_id"/>
        </createIndex>
        <createIndex indexName="idx_alerts_org" tableName="alerts">
            <column name="organization_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
