logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pom.log

# Testing
coverage/
.nyc_output/
.pytest_cache/
__pycache__/
*.pyc

# OS
Thumbs.db
*.DS_Store

# Docker
.dockerignore

# Runtime
.cache/
*.cache
.venv/
venv/
ENV/

# Temporary files
*.tmp
*.temp
.tmp/

# Packages
*.zip
*.tar.gz
*.tgz

# IntelliJ
*.iml
.project
.classpath
.c9/

# VS Code
.history/
.vscode-test/

# Python
*.egg-info/
dist/
build/

# Node
package-lock.json
yarn.lock

# AWS
.aws/credentials

# Terraform
*.tfstate
*.tfstate.backup
.terraform/
.terraform.lock.hcl

# Kubernetes
kubeconfig
.kube/

# Documentation
site/

# Optional npm cache directory
.npm

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# dotenv environment variables file
.env

# Mac files
.DS_Store
.AppleDouble
.LSOverride

# Windows files
Desktop.ini

